# ─── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/
build/

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example committed (it has no real secrets)
!.env.example

# ─── Python crawler ───────────────────────────────────────────────────────────
# Virtual environments
crawler/.venv/
crawler/venv/
crawler/__pycache__/
crawler/**/__pycache__/
crawler/*.pyc
crawler/**/*.pyc
crawler/*.pyo

# Crawler output (can be huge — hundreds of MB of JSONL)
crawler/output/

# Crawler logs
crawler/logs/

# fastembed model cache (downloaded on first run, ~150 MB)
crawler/.fastembed_cache/
crawler/models/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.orig

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel/

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
.cache/
tmp/
temp/
