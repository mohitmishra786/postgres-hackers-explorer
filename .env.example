# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Pooled connection (PgBouncer) — used by Next.js API routes at runtime
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Unpooled — used by the Python crawler/ingest pipeline (bulk inserts)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Upstash Redis ──────────────────────────────────────────────────────────────
# Rate limiting + API response caching
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Groq ───────────────────────────────────────────────────────────────────────
# Primary LLM for /api/ask (llama-3.3-70b-versatile / llama-3.1-8b-instant)
# and thread summarization in ingest.py
# Free tier at console.groq.com
GROQ_API_KEY=gsk_...

# ── HuggingFace ────────────────────────────────────────────────────────────────
# Query-time embeddings in Next.js (BAAI/bge-small-en-v1.5, 384 dims, free)
# Optional — works without a key on the free inference API, but a key
# raises rate limits significantly. Get one at huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# ── Optional: OpenAI embeddings ────────────────────────────────────────────────
# Only needed if you set EMBEDDING_PROVIDER=openai in the crawler.
# Default is fastembed (local, no key needed).
# OPENAI_API_KEY=sk-...
# EMBEDDING_PROVIDER=openai
